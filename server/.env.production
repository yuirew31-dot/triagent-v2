# Render Production Environment Variables
# Copy your API keys from your local .env file

# ===== AI API KEYS =====
FIREWORKS_API_KEY=your_fireworks_key_here
SILICONFLOW_API_KEY=your_siliconflow_key_here
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
COHERE_API_KEY=your_cohere_key_here
GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ===== SERVER CONFIG =====
NODE_ENV=production
PORT=10000
HOST=0.0.0.0

# ===== DATABASE =====
# Render sets this automatically - do NOT edit in Render dashboard
# DATABASE_URL=postgresql://... (auto-set by Render)

# ===== PERFORMANCE (for free tier) =====
MAX_CONCURRENT_TASKS=2
CACHE_MAX_SIZE=100
CONTEXT_COMPRESSION_ENABLED=true

# ===== OPTIONAL: MONITORING =====
# LOG_LEVEL=info
# SENTRY_DSN=  (for error tracking)
