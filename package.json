{
  "name": "triagent-v2",
  "version": "2.0.0",
  "description": "40-file Node.js + Fastify + React + SQLite multi-agent AI system with Arena Leaderboard models",
  "type": "module",
  "main": "server/dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx watch server/src/index.ts",
    "server:build": "tsc --project server/tsconfig.json",
    "server:start": "node server/dist/index.js",
    "client:dev": "cd client && vite",
    "client:build": "cd client && vite build",
    "client:preview": "cd client && vite preview",
    "build:all": "npm run server:build && npm run client:build",
    "start:prod": "node server/dist/index.js",
    "db:init": "tsx server/src/db.ts",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^10.0.0",
    "@google/generative-ai": "^0.1.3",
    "cohere-ai": "^7.0.0",
    "fastify": "^4.25.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.8.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.5",
    "vitest": "^1.0.4"
  }
}
