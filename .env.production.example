# Environment Variables for Production Deployment

# ============ API KEYS (Copy from your local .env) ============
FIREWORKS_API_KEY=your_key_here
SILICONFLOW_API_KEY=your_key_here
GEMINI_API_KEY_1=your_key_here
GEMINI_API_KEY_2=your_key_here
COHERE_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# ============ SERVER CONFIGURATION ============
PORT=3000
NODE_ENV=production
DB_PATH=/data/triagent.db
ENCRYPTION_SECRET=your-secure-32-char-secret-here

# ============ CORS CONFIGURATION ============
# Set to your deployed domain
CORS_ORIGIN=https://triagent-v2-production.up.railway.app

# ============ DATABASE ============
# SQLite will be stored in /data/triagent.db
# Make sure /data directory exists and is writable
